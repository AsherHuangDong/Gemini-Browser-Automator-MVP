# Gemini 浏览器自动化 MVP - 环境变量示例
# 复制这个文件为 .env 并根据你的需求修改

# 浏览器配置
PROFILE_DIR=./profiles
HEADLESS=False
TIMEOUT=30
RETRY_COUNT=3

# 使用已安装的浏览器（可选）
# 如果设置了此项，将使用指定的浏览器而不是 Playwright 自带的 Chromium
# Windows 示例: BROWSER_PATH=C:\\Program Files\\Google\\Chrome\\Application\\chrome.exe
# macOS 示例: BROWSER_PATH=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome
# Linux 示例: BROWSER_PATH=/usr/bin/google-chrome
# BROWSER_PATH=

# Gemini 配置
GEMINI_BASE_URL=https://gemini.google.com
GEMINI_RESPONSE_TIMEOUT=300
